{
  "name": "timezone-i18n",
  "version": "1.2.0",
  "description": "World time zone dataset with multilingual city and country translations for TypeScript, JavaScript, Node.js and modern frontend frameworks.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "timezone",
    "timezones",
    "i18n",
    "localization",
    "multilingual",
    "internationalization",
    "saat-dilimi",
    "saat-dilimleri",
    "yerelleştirme",
    "world-clock",
    "global-time",
    "timezone-data",
    "timezone-dataset",
    "offset",
    "gmt",
    "utc",
    "countries-timezone",
    "iana-timezone",
    "date-time",
    "react-timezone",
    "nextjs-timezone",
    "node-timezone",
    "typescript-timezone",
    "turkey-timezone",
    "kazakhstan-timezone",
    "mexico-timezone",
    "current-time",
    "dst",
    "world-timezones",
    "angular-timezone",
    "vue-timezone",
    "timezone-picker",
    "timezone-select",
    "iana",
    "olson",
    "multilang-timezone",
    "arabic-timezone",
    "chinese-timezone",
    "hindi-timezone",
    "indonesian-timezone",
    "japanese-timezone",
    "russian-timezone",
    "timezone-abbr",
    "timezone-offset",
    "rawoffset",
    "hasdst",
    "isocode",
    "flag-timezone",
    "intl-datetimeformat",
    "luxon-timezone",
    "moment-timezone"
  ],
  "author": "Emrah AKCAL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmrahAKCAL/timezone-i18n.git"
  },
  "bugs": {
    "url": "https://github.com/EmrahAKCAL/timezone-i18n/issues"
  },
  "homepage": "https://github.com/EmrahAKCAL/timezone-i18n#readme",
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  }
}