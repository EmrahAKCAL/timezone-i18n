{
  "name": "timezone-i18n",
 "version": "1.1.0",
  "description": "Enterprise-grade world time zone dataset with 20 multilingual localizations (EN, TR, AR, BG, BN, DE, ES, FR, HI, ID, IT, JA, NL, PL, PT, RO, RU, UK, UR, ZH). Built for high-performance frontend and backend production.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
